{% extends "base.html" %}
{% block title %}FlipAFind — Turn Any Product Into Profit{% endblock %}
{% block content %}

<!-- Hero Section -->
<section class="relative overflow-hidden grid-bg">
  <!-- Background orbs -->
  <div class="absolute top-1/4 left-1/5 w-[500px] h-[500px] bg-indigo-600/15 rounded-full blur-[120px] animate-pulse pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/5 w-[400px] h-[400px] bg-purple-600/15 rounded-full blur-[100px] animate-pulse pointer-events-none" style="animation-delay:1.5s"></div>
  <div class="absolute top-1/2 left-1/2 w-[300px] h-[300px] bg-blue-600/8 rounded-full blur-[80px] -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 pt-20 pb-12">
    <!-- Top badge -->
    <div class="flex justify-center mb-8">
      <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/25 text-indigo-300 text-sm px-4 py-2 rounded-full font-medium tracking-tight">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse inline-block"></span>
        Powered by 4 AI Agents &nbsp;·&nbsp; Real-time market research
      </div>
    </div>

    <!-- Headline -->
    <h1 class="font-heading font-bold text-5xl sm:text-6xl lg:text-7xl text-gradient mb-6 leading-[1.1] tracking-tight text-center">
      Turn Any Product<br>Into Profit
    </h1>

    <!-- Subheadline -->
    <p class="text-lg sm:text-xl text-[#f1f5f9]/55 max-w-2xl mx-auto mb-10 leading-relaxed text-center">
      Describe any item or paste a URL. AI researches sold prices, auction results, and cheaper sources — delivering exact flip numbers in seconds.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-14">
      <a href="{{ url_for('auth.signup') }}" class="btn-primary px-8 py-4 text-base">
        Start For Free
        <i data-lucide="arrow-right" class="w-5 h-5 ml-2 inline"></i>
      </a>
      <a href="#how-it-works" class="btn-outline px-8 py-4 text-base">
        See How It Works
        <i data-lucide="chevron-down" class="w-5 h-5 ml-2 inline"></i>
      </a>
    </div>

    <!-- Floating stat badges -->
    <div class="flex flex-wrap justify-center gap-2.5 mb-16">
      <span class="stat-badge">📈 180% Avg ROI</span>
      <span class="stat-badge">🔍 10,000+ Products Analysed</span>
      <span class="stat-badge">🌍 40+ Countries</span>
      <span class="stat-badge">🤖 4 AI Agents</span>
    </div>

    <!-- App preview card -->
    <div class="relative max-w-md mx-auto pt-7 pb-7">
      <!-- Glow beneath card -->
      <div class="preview-card-glow"></div>

      <div class="glow-card p-5 text-left" style="background: linear-gradient(145deg, #1a1a28, #141420);">
        <!-- Header row -->
        <div class="flex items-start gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl flex-shrink-0 mt-0.5"
               style="background: linear-gradient(135deg, rgba(99,102,241,0.25), rgba(168,85,247,0.2)); border: 1px solid rgba(99,102,241,0.2);">
            👟
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-heading font-semibold text-sm text-[#f1f5f9] truncate tracking-tight">Nike Air Jordan 1 Retro High OG</div>
            <div class="text-xs text-[#52526a] mt-0.5">Chicago · US10 · Used Once · Original Box</div>
            <span class="inline-block mt-1.5 text-xs px-2.5 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/25 font-bold tracking-wide">STRONG FLIP</span>
          </div>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-3 gap-2 mb-4">
          <div class="rounded-xl p-3 text-center" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
            <div class="text-[#52526a] text-xs mb-1">Buy At</div>
            <div class="font-heading font-bold text-[#f1f5f9] text-sm">$140</div>
          </div>
          <div class="rounded-xl p-3 text-center" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
            <div class="text-[#52526a] text-xs mb-1">Sell For</div>
            <div class="font-heading font-bold text-[#f1f5f9] text-sm">$310</div>
          </div>
          <div class="rounded-xl p-3 text-center" style="background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);">
            <div class="text-emerald-400/70 text-xs mb-1">Net ROI</div>
            <div class="font-heading font-bold text-emerald-400 text-sm">+121%</div>
          </div>
        </div>

        <!-- After shipping row -->
        <div class="flex items-center justify-between text-xs mb-3 px-0.5">
          <span class="text-[#52526a]">After shipping &amp; fees</span>
          <span class="text-[#f1f5f9]/80 font-semibold">+$124 true profit</span>
        </div>

        <!-- Score bar -->
        <div class="flex items-center gap-3 mb-3">
          <div class="flex-1 bg-[#111118] rounded-full h-1.5 overflow-hidden">
            <div class="h-1.5 rounded-full" style="width: 82%; background: linear-gradient(90deg, #6366f1, #a855f7);"></div>
          </div>
          <span class="text-xs text-[#52526a] flex-shrink-0 font-medium">82/100</span>
        </div>

        <!-- Footer row -->
        <div class="flex items-center justify-between">
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs px-2 py-0.5 rounded-full bg-indigo-500/15 text-indigo-300 border border-indigo-500/20">eBay recommended</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400 border border-amber-500/20">Low risk</span>
          </div>
          <span class="text-[#52526a] text-xs">AI estimate</span>
        </div>
      </div>

      <!-- Floating labels — only visible on large screens where card has room -->
      <div class="absolute right-0 lg:-right-6 -top-5 lg:top-4 flex items-center gap-1.5 bg-emerald-500/15 border border-emerald-500/25 text-emerald-400 text-xs font-semibold px-3 py-1.5 rounded-full shadow-lg backdrop-blur-sm">
        <i data-lucide="trending-up" class="w-3.5 h-3.5"></i> ROI tracked
      </div>
      <div class="absolute left-0 lg:-left-8 -bottom-5 lg:bottom-8 flex items-center gap-1.5 bg-indigo-500/15 border border-indigo-500/25 text-indigo-300 text-xs font-semibold px-3 py-1.5 rounded-full shadow-lg backdrop-blur-sm">
        <i data-lucide="search" class="w-3.5 h-3.5"></i> 14 platforms searched
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section id="how-it-works" class="py-24" style="background: #0e0e18;">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <div class="inline-block text-xs font-semibold text-indigo-400 uppercase tracking-widest mb-3 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20">How It Works</div>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gradient mb-4 tracking-tight">Four agents. One result.</h2>
      <p class="text-[#f1f5f9]/50">Working in parallel in under 60 seconds</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      <div class="how-card">
        <div class="icon-box">📷</div>
        <div class="text-indigo-400 text-xs font-bold mb-2 uppercase tracking-wider">Step 1</div>
        <h3 class="font-heading font-bold text-lg mb-2 tracking-tight">Upload or Describe</h3>
        <p class="text-[#f1f5f9]/45 text-sm leading-relaxed">Photo, text description, or product URL — we handle it all</p>
      </div>
      <div class="how-card">
        <div class="icon-box">🔍</div>
        <div class="text-indigo-400 text-xs font-bold mb-2 uppercase tracking-wider">Step 2</div>
        <h3 class="font-heading font-bold text-lg mb-2 tracking-tight">Extract Details</h3>
        <p class="text-[#f1f5f9]/45 text-sm leading-relaxed">AI identifies brand, model, era, condition, style and demand level</p>
      </div>
      <div class="how-card">
        <div class="icon-box">💹</div>
        <div class="text-indigo-400 text-xs font-bold mb-2 uppercase tracking-wider">Step 3</div>
        <h3 class="font-heading font-bold text-lg mb-2 tracking-tight">Research Markets</h3>
        <p class="text-[#f1f5f9]/45 text-sm leading-relaxed">Searches eBay, Depop, Poshmark, Mercari, StockX, GOAT, and auction houses</p>
      </div>
      <div class="how-card">
        <div class="icon-box">📊</div>
        <div class="text-indigo-400 text-xs font-bold mb-2 uppercase tracking-wider">Step 4</div>
        <h3 class="font-heading font-bold text-lg mb-2 tracking-tight">Calculate Profit</h3>
        <p class="text-[#f1f5f9]/45 text-sm leading-relaxed">Exact ROI, platform fees, break-even price, and listing tips</p>
      </div>
    </div>
  </div>
</section>

<!-- Platforms Marquee -->
<section class="py-12 border-y border-[#252532] overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 text-center mb-8">
    <p class="text-[#52526a] text-xs uppercase tracking-[0.15em] font-semibold">Platforms We Research</p>
  </div>
  <div class="marquee-wrapper">
    <div class="marquee-track gap-3 px-4" style="display: flex; gap: 0.75rem;">
      {% set platforms = [
        ('eBay', '🛒'), ('Depop', '👗'), ('Poshmark', '👜'), ('Mercari', '📦'),
        ('StockX', '👟'), ('GOAT', '🐐'), ('Grailed', '🧥'), ('OfferUp', '🏷️'),
        ("Sotheby's", '🏛️'), ("Christie's", '🖼️'), ('Heritage', '⚒️'),
        ('FB Marketplace', '📍'), ('Vestiaire', '💎'), ('Chairish', '🪑'),
        ('eBay', '🛒'), ('Depop', '👗'), ('Poshmark', '👜'), ('Mercari', '📦'),
        ('StockX', '👟'), ('GOAT', '🐐'), ('Grailed', '🧥'), ('OfferUp', '🏷️'),
        ("Sotheby's", '🏛️'), ("Christie's", '🖼️'), ('Heritage', '⚒️'),
        ('FB Marketplace', '📍'), ('Vestiaire', '💎'), ('Chairish', '🪑')
      ] %}
      {% for name, emoji in platforms %}
        <span class="platform-pill">{{ emoji }} {{ name }}</span>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Beta Banner -->
<section class="py-3.5 border-b border-emerald-500/15 text-center" style="background: rgba(16,185,129,0.05);">
  <p class="text-emerald-400/80 text-sm font-medium">
    🎉 Beta Launch — All features are completely free. No credit card required.
  </p>
</section>

<!-- Pricing -->
<section class="py-24 bg-[#09090f]">
  <div class="max-w-5xl mx-auto px-4 text-center">
    <div class="inline-block text-xs font-semibold text-indigo-400 uppercase tracking-widest mb-3 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20">Pricing</div>
    <h2 class="font-heading font-bold text-3xl sm:text-4xl text-gradient mb-4 tracking-tight">Simple, transparent pricing</h2>
    <div class="inline-flex items-center gap-2 bg-orange-500/10 border border-orange-500/30 text-orange-400 text-sm font-semibold px-4 py-2 rounded-full mb-4">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
      Limited Time — Save 50% on Pro
    </div>
    <p class="text-[#f1f5f9]/50 mb-10">Choose the plan that suits your flipping business</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Free -->
      <div class="pricing-card text-left">
        <div class="text-[#52526a] text-xs font-bold uppercase tracking-wider mb-3">Free</div>
        <div class="flex items-end gap-1 mb-1">
          <span class="font-heading font-extrabold text-4xl tracking-tight">$0</span>
          <span class="text-[#52526a] text-sm mb-1">/month</span>
        </div>
        <p class="text-[#52526a] text-sm mb-6">Get started at no cost</p>
        <ul class="space-y-2.5 text-sm text-[#f1f5f9]/65 mb-8">
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> 3 analyses/month</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> Basic results</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> eBay + Depop search</li>
        </ul>
        <a href="{{ url_for('auth.signup') }}" class="btn-outline w-full text-center py-2.5">Get Started</a>
      </div>
      <!-- Pro -->
      <div class="pricing-card popular-card relative text-left">
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-gradient-to-r from-indigo-600 to-purple-600 text-white text-xs font-bold px-4 py-1 rounded-full tracking-wide shadow-lg">MOST POPULAR</div>
        <div class="absolute -top-3.5 right-3 bg-orange-500 text-white text-xs font-bold px-2 py-1 rounded-full">50% OFF</div>
        <div class="text-indigo-400 text-xs font-bold uppercase tracking-wider mb-3">Pro</div>
        <div class="flex items-baseline gap-2 mb-1">
          <span class="font-heading font-extrabold text-4xl tracking-tight">$14.99</span>
          <span class="text-[#52526a] text-lg line-through">$29.99</span>
        </div>
        <div class="text-xs mb-1"><span class="text-sm mb-1 text-[#52526a]">/month</span> <span class="text-orange-400 font-semibold">· lock in this rate forever</span></div>
        <p class="text-[#52526a] text-sm mb-6">For serious resellers</p>
        <ul class="space-y-2.5 text-sm text-[#f1f5f9]/65 mb-8">
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> 50 analyses/month</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> All 14 platforms searched</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> Auction house results</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> Similar item finder</li>
        </ul>
        <a href="{{ url_for('auth.signup') }}" class="btn-primary w-full text-center py-2.5">Start Pro</a>
      </div>
      <!-- Premium -->
      <div class="pricing-card text-left">
        <div class="text-purple-400 text-xs font-bold uppercase tracking-wider mb-3">Premium</div>
        <div class="flex items-end gap-1 mb-1">
          <span class="font-heading font-extrabold text-4xl tracking-tight">$39.99</span>
          <span class="text-[#52526a] text-sm mb-1">/month</span>
        </div>
        <p class="text-[#52526a] text-sm mb-6">For power flippers</p>
        <ul class="space-y-2.5 text-sm text-[#f1f5f9]/65 mb-8">
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> Unlimited analyses</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> Priority processing</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> Export to CSV</li>
          <li class="flex gap-2.5 items-start"><i data-lucide="check" class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5"></i> API access</li>
        </ul>
        <a href="{{ url_for('auth.signup') }}" class="btn-outline w-full text-center py-2.5">Go Premium</a>
      </div>
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="cta-banner py-20 text-center">
  <div class="relative max-w-3xl mx-auto px-4">
    <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/80 text-sm px-4 py-1.5 rounded-full mb-6 font-medium">
      <i data-lucide="zap" class="w-3.5 h-3.5"></i> Free during beta
    </div>
    <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-white mb-4 tracking-tight">Ready to start flipping?</h2>
    <p class="text-white/60 mb-8 text-lg">Join thousands of resellers using AI to find profitable deals.</p>
    <a href="{{ url_for('auth.signup') }}" class="bg-white text-indigo-700 font-bold px-9 py-4 rounded-xl hover:bg-white/95 hover:shadow-2xl transition-all inline-block text-base tracking-tight">
      Create Free Account →
    </a>
  </div>
</section>

{% endblock %}
